{
  "name": "adcelerate-instagram-scrapper",
  "version": "0.1.0",
  "type": "module",
  "description": "Instagram content scraper that extracts posts, reels, and profile data from Instagram URLs",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test",
    "lint": "bunx @biomejs/biome check .",
    "check": "bunx @biomejs/biome check --write ."
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
